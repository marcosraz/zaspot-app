{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "ios": {
        "simulator": false,
        "distribution": "store",
        "autoIncrement": true
      }
    },
    "production": {
      "ios": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "marek.heidinger@gmail.com",
        "appleTeamId": "2DR983VXCS",
        "ascAppId": "6770471470",
        "ascApiKeyPath": "$ASC_API_KEY_PATH",
        "ascApiKeyId": "$ASC_API_KEY_ID",
        "ascApiKeyIssuerId": "$ASC_API_KEY_ISSUER_ID"
      }
    },
    "production": {
      "ios": {
        "appleId": "marek.heidinger@gmail.com",
        "appleTeamId": "2DR983VXCS",
        "ascAppId": "6770471470",
        "ascApiKeyPath": "$ASC_API_KEY_PATH",
        "ascApiKeyId": "$ASC_API_KEY_ID",
        "ascApiKeyIssuerId": "$ASC_API_KEY_ISSUER_ID"
      }
    }
  }
}
